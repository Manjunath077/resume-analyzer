{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "types": ["node"]
  },
  "include": [
    "src/workers/**/*",
    "src/features/**/*",
    "src/lib/**/*",
    "src/config/**/*"
  ]
}